# Required in production
SESSION_SECRET=replace-with-a-long-random-string

# PostgreSQL connection string (leave empty to use local SQLite)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Render sets this automatically)
PORT=5000

# Set automatically by Render/Docker; leave as-is
NODE_ENV=production

# SQLite file path (only used when DATABASE_URL is not set)
DATABASE_PATH=./deve.db

# Optional: restrict CORS to a specific origin
# CORS_ORIGIN=https://your-frontend-domain.com
